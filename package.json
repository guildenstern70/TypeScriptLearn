{
    "name": "typescriptlearn",
    "version": "0.1.2",
    "description": "A project containing all main features of TypeScript",
    "repository": "https://github.com/guildenstern70/TypeScriptLearn",
    "license": "MIT",
    "author": {
        "name": "Alessio Saltarin",
        "email": "alessiosaltarin@gmail.com"
    },
    "keywords": [
        "typescript"
    ],
    "files": [
        "lib"
    ],
    "main": "lib/index.js",
    "typings": "lib/index.d.ts",
    "scripts": {
        "clean": "rimraf lib",
        "build": "tsc",
        "lint": "npx eslint 'src/**/*.ts'",
        "lint:fix": "npm run lint -- --fix",
        "prettier": "npx prettier 'src/**/*.ts' --check",
        "prettier:fix": "npm run prettier --write",
        "format": "npm run prettier:fix && npm run lint:fix",
        "test": "jest --verbose"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.1",
        "@typescript-eslint/parser": "^8.48.1",
        "@typescript-eslint/eslint-plugin": "^8.48.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "jest": "^30.2.0",
        "prettier": "^3.7.3",
        "prettier-eslint": "^16.4.2",
        "rimraf": "^6.1.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=22"
    },
    "jest": {
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ]
    }
}
