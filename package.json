{
    "name": "typescriptlearn",
    "version": "0.1.4",
    "description": "A project containing all main features of TypeScript",
    "repository": "https://github.com/guildenstern70/TypeScriptLearn",
    "license": "MIT",
    "author": {
        "name": "Alessio Saltarin",
        "email": "alessiosaltarin@gmail.com"
    },
    "keywords": [
        "typescript"
    ],
    "files": [
        "lib"
    ],
    "main": "lib/index.js",
    "typings": "lib/index.d.ts",
    "scripts": {
        "clean": "rimraf lib",
        "build": "tsc",
        "lint": "npx eslint 'src/**/*.ts'",
        "lint:fix": "npm run lint -- --fix",
        "prettier": "npx prettier 'src/**/*.ts' --check",
        "prettier:fix": "npm run prettier --write",
        "format": "npm run prettier:fix && npm run lint:fix",
        "test": "jest --verbose"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.3",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "jest": "^30.4.2",
        "prettier": "^3.8.4",
        "prettier-eslint": "^17.1.0",
        "rimraf": "^6.1.3",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=22"
    },
    "jest": {
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json",
            "node"
        ],
        "modulePathIgnorePatterns": [
            "<rootDir>/lib/"
        ]
    }
}
